#nexus

BEGIN Taxa;
DIMENSIONS ntax=10;
TAXLABELS
[1] 'seq1'
[2] 'seq2'
[3] 'seq3'
[4] 'seq4'
[5] 'seq5'
[6] 'seq6'
[7] 'seq7'
[8] 'seq8'
[9] 'seq9'
[10] 'seq10'
;
END; [Taxa]

BEGIN Splits;
DIMENSIONS ntax=10 nsplits=24;
FORMAT labels=no weights=yes confidences=no intervals=no;
MATRIX
	100	 2,
	100	 3,
	100	 4,
	100	 5,
	100	 4 5,
	100	 6,
	100	 7,
	100	 8,
	100	 7 8,
	100	 6 7 8,
	99	 1 2 3 9 10,
	100	 9,
	100	 10,
	100	 9 10,
	99	 1 2 3,
	31	 1 2,
	100	 1,
	39	 1 3,
	30	 2 3,
	1	 1 3 9 10,
	0	 3 9 10,
	1	 1 2 3 4 5,
	1	 1 9 10,
	0	 1 2 9 10,
;
END; [Splits]

