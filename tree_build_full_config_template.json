{
  "run": {
    "input_type": "PROTEIN",
    "input_file": "/absolute/path/to/aligned_input.fasta",
    "output_base_dir": "/absolute/path/to/output_root",
    "output_prefix": "demo_run",
    "language": "english"
  },
  "alignment": {
    "run_alignment_first": false,
    "strategy": "genafpair",
    "maxiterate": 1000,
    "reorder": true,
    "mafft": {
      "common": {
        "strategy": "genafpair",
        "maxiterate": 1000,
        "threads": 8,
        "reorder": true
      },
      "advanced": {},
      "extra_args": [
        "--retree",
        "2"
      ]
    }
  },
  "reroot": {
    "method": "MAD",
    "ladderization": {
      "direction": "UP",
      "sort_by_clade_size": true,
      "sort_by_branch_length": true
    }
  },
  "methods": {
    "distance": {
      "enabled": true,
      "protdist": {
        "common": {},
        "advanced": {},
        "menu_overrides": []
      },
      "dnadist": {
        "common": {
          "dnadist_model": "F84",
          "dnadist_transition_transversion_ratio": 2.0,
          "dnadist_empirical_base_frequencies": true
        },
        "advanced": {},
        "menu_overrides": []
      },
      "neighbor": {
        "common": {
          "neighbor_method": "NJ",
          "neighbor_outgroup_index": null
        },
        "advanced": {},
        "menu_overrides": []
      }
    },
    "maximum_likelihood": {
      "enabled": true,
      "iqtree": {
        "common": {
          "bootstrap_replicates": 1000,
          "model_strategy": "MFP",
          "model_set": ""
        },
        "advanced": {
          "threads": "AUTO",
          "threads_max": 8,
          "seed": 42,
          "safe": false,
          "keep_ident": false,
          "quiet": true,
          "verbose": false,
          "redo": true,
          "memory_limit": "8G",
          "outgroup": "",
          "sequence_type": "",
          "alrt": 1000,
          "abayes": false
        },
        "extra_args": []
      }
    },
    "bayesian": {
      "enabled": true,
      "mrbayes": {
        "common": {
          "protein_model_prior": "mixed",
          "nst": 6,
          "rates": "invgamma",
          "ngen": 50000,
          "samplefreq": 100,
          "printfreq": 1000,
          "diagnfreq": 5000
        },
        "advanced": {
          "nruns": 2,
          "nchains": 4,
          "temp": 0.2,
          "stoprule": true,
          "stopval": 0.01,
          "burnin": 0,
          "burninfrac": 0.25,
          "relburnin": true
        },
        "command_block": []
      }
    },
    "parsimony": {
      "enabled": true,
      "protpars": {
        "common": {
          "protpars_outgroup_index": null,
          "protpars_print_steps": true,
          "protpars_print_sequences": true
        },
        "advanced": {},
        "menu_overrides": []
      },
      "dnapars": {
        "common": {
          "dnapars_outgroup_index": null,
          "dnapars_transversion_parsimony": false
        },
        "advanced": {},
        "menu_overrides": []
      }
    },
    "protein_structure": {
      "enabled": false,
      "backend": "foldseek",
      "use_structure_manifest": false,
      "structure_manifest_file": null,
      "prostt5_model_path": null,
      "sequence_only_mode": "prostt5",
      "similarity_rule": "mean_qtmscore_ttmscore",
      "missing_distance": "1"
    }
  }
}
