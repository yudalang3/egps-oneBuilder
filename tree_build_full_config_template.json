{
  "run": {
    "input_type": "PROTEIN",
    "input_file": "/absolute/path/to/aligned_input.fasta",
    "output_base_dir": "/absolute/path/to/output_root",
    "output_prefix": "demo_run"
  },
  "alignment": {
    "run_alignment_first": false,
    "strategy": "genafpair",
    "maxiterate": 1000,
    "reorder": true,
    "mafft": {
      "common": {
        "strategy": "genafpair",
        "maxiterate": 1000,
        "threads": 8,
        "reorder": true
      },
      "advanced": {},
      "extra_args": [
        "--retree",
        "2"
      ]
    }
  },
  "methods": {
    "distance": {
      "enabled": true,
      "protdist": {
        "common": {},
        "advanced": {},
        "menu_overrides": []
      },
      "dnadist": {
        "common": {},
        "advanced": {},
        "menu_overrides": []
      },
      "neighbor": {
        "common": {},
        "advanced": {},
        "menu_overrides": []
      }
    },
    "maximum_likelihood": {
      "enabled": true,
      "iqtree": {
        "common": {
          "bootstrap_replicates": 1000,
          "model_strategy": "MFP",
          "model_set": "LG,WAG,JTT"
        },
        "advanced": {
          "threads": "AUTO",
          "threads_max": 8,
          "seed": 42,
          "safe": false,
          "keep_ident": false,
          "quiet": true,
          "verbose": false,
          "redo": true,
          "memory_limit": "8G",
          "outgroup": "",
          "sequence_type": "",
          "alrt": 1000,
          "abayes": false
        },
        "extra_args": []
      }
    },
    "bayesian": {
      "enabled": true,
      "mrbayes": {
        "common": {
          "protein_model_prior": "mixed",
          "nst": 6,
          "rates": "invgamma",
          "ngen": 50000,
          "samplefreq": 100,
          "printfreq": 1000,
          "diagnfreq": 5000
        },
        "advanced": {
          "nruns": 2,
          "nchains": 4,
          "temp": 0.2,
          "stoprule": true,
          "stopval": 0.01,
          "burnin": 0,
          "burninfrac": 0.25,
          "relburnin": true
        },
        "command_block": []
      }
    },
    "parsimony": {
      "enabled": true,
      "protpars": {
        "common": {},
        "advanced": {},
        "menu_overrides": []
      },
      "dnapars": {
        "common": {},
        "advanced": {},
        "menu_overrides": []
      }
    }
  }
}
